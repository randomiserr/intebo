# Intebo Lieferplan Parser — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Path to data directory (plans, inventory, state files)
# Default: ./data (relative to app root)
# Examples:
#   D:\intebo-data                          (Windows local)
#   \\server\share\intebo-data              (Windows network drive)
#   /mnt/storage/intebo-data                (Linux / mounted cloud storage)
INTEBO_DATA_DIR=./data
